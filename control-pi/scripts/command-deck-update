#!/usr/bin/env bash
set -Eeuo pipefail

progress() {
    printf 'PROGRESS %s %s\n' "$1" "$2"
}

fail() {
    printf 'ERROR %s\n' "$1"
    exit 1
}

tmpdir=
cleanup() {
    [[ -z $tmpdir ]] || rm -rf "$tmpdir"
}

trap cleanup EXIT
trap 'fail "Update failed near line $LINENO"' ERR

[[ $EUID -eq 0 ]] || fail "Updater must run through sudo"
[[ $# -eq 1 ]] || fail "Updater requires exactly one release URL"
[[ $1 == https://* ]] || fail "Release URL must use HTTPS"

release_url=$1
archive_name=command-deck-linux-arm64.tar.gz
checksum_name=$archive_name.sha256
tmpdir=$(mktemp -d)
archive=$tmpdir/$archive_name
checksum=$tmpdir/$checksum_name
extract_dir=$tmpdir/extract
mkdir "$extract_dir"

progress 10 "Downloading latest release"
curl --fail --location --silent --show-error \
    --retry 3 --retry-delay 2 --retry-all-errors \
    --output "$archive" "$release_url"
curl --fail --location --silent --show-error \
    --retry 3 --retry-delay 2 --retry-all-errors \
    --output "$checksum" "$release_url.sha256"

progress 45 "Verifying release checksum"
expected_checksum=$(<"$checksum")
[[ $expected_checksum =~ ^[[:xdigit:]]{64}[[:space:]][[:space:]]command-deck-linux-arm64\.tar\.gz$ ]] ||
    fail "Release checksum file is malformed"
(cd "$tmpdir" && sha256sum --check --status "$checksum_name") ||
    fail "Release checksum verification failed"

progress 60 "Validating release package"
archive_files=$(tar -tzf "$archive")
[[ $archive_files == command-deck$'\n'lib/$'\n'lib/libwebsockets.so.* ]] ||
    fail "Release archive contains unexpected files"
tar -xzf "$archive" -C "$extract_dir" --no-same-owner --no-same-permissions
binary=$extract_dir/command-deck
[[ -f $binary && ! -L $binary ]] || fail "Release does not contain a regular dashboard binary"
library=$(find "$extract_dir/lib" -maxdepth 1 -type f -name 'libwebsockets.so.*' -print -quit)
[[ -n $library && ! -L $library ]] || fail "Release does not contain libwebsockets"
file -b "$binary" | grep -Eq 'ARM aarch64|ARM64' ||
    fail "Release dashboard binary is not ARM64"
file -b "$library" | grep -Eq 'ARM aarch64|ARM64' ||
    fail "Release libwebsockets is not ARM64"
LD_LIBRARY_PATH="$extract_dir/lib" ldd "$binary" | grep -q 'not found' &&
    fail "Release has unavailable runtime dependencies"

progress 85 "Installing dashboard"
candidate=/usr/local/bin/.command-deck.new.$$
library_dir=/usr/local/lib/command-deck
mkdir -p "$library_dir"
install -o root -g root -m 0755 "$library" "$library_dir/"
install -o root -g root -m 0755 "$binary" "$candidate"
if ldd "$candidate" | grep -q 'not found'; then
    rm -f "$candidate"
    fail "Installed candidate has unavailable runtime dependencies"
fi
if [[ -f /usr/local/bin/command-deck ]]; then
    install -o root -g root -m 0755 /usr/local/bin/command-deck \
        /usr/local/bin/command-deck.previous
fi
mv -f "$candidate" /usr/local/bin/command-deck

progress 100 "Update installed; restarting dashboard"
unit="command-deck-restart-$(date +%s)"
systemd-run --quiet --unit="$unit" --on-active=3s \
    /bin/systemctl restart command-deck.service
